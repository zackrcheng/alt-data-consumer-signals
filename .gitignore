# Credentials — never commit
.env

# Data — raw files can be large or licensed
data/raw/*.csv
# FactSet exports are licensed — do not redistribute
data/raw/factset_*.xlsx
data/processed/*.csv

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
dist/
build/

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# IDE configs
.idea/
.vscode/

# Jupyter checkpoints
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/

# Logs
*.log

# macOS
.DS_Store

# Outputs (charts/tables re-generated by scripts — don't version-control)
# EXCEPTION: q1_2026_preregistered.csv must be tracked to prove the
# prediction was committed before the May 6 2026 earnings print.
outputs/figures/*.png
outputs/tables/*.csv
!outputs/tables/q1_2026_preregistered.csv

# Project-private docs (working spec, transcripts, source materials)
CLAUDE.md
/docs/
.claude
