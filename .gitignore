*.py[cod]
*.egg-info/
.venv/
dist/
build/

# Jupyter checkpoints
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/

# macOS
.DS_Store

# Outputs (charts/tables re-generated by scripts — don't version-control)
outputs/figures/*.png
outputs/tables/*.csv
CLAUDE.md
docs
.claude
