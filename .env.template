# Copy this file to .env and fill in your credentials.
# .env is gitignored — never commit actual credentials.

# FRED API key — register free at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# WRDS username — https://wrds-www.wharton.upenn.edu/
WRDS_USERNAME=your_wrds_username_here

# Alpha Vantage API key — register free at https://www.alphavantage.co/support/#api-key
# Used as fallback when yfinance is rate-limited. Free tier: 25 calls/day, 5 calls/min.
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
